{
  "name": "richard8768/hyperf-passport",
  "type": "library",
  "license": "MIT",
  "keywords": [
    "php",
    "hyperf",
    "oauth",
    "oauth2",
    "passport"
  ],
  "description": "Hyperf Passport provides OAuth2 server support to Hyperf",
  "authors": [
    {
      "name": "richard8768",
      "email": "444626008@qq.com"
    }
  ],
  "require": {
    "php": ">=8.2",
    "ext-swoole": ">=5.0",
    "ext-json": "*",
    "firebase/php-jwt": "^7.0",
    "guzzlehttp/guzzle": "^7.0",
    "hyperf/command": "^3.2",
    "hyperf/contract": "^3.2",
    "hyperf/database": "^3.2",
    "hyperf/db-connection": "^3.2",
    "hyperf/di": "^3.2",
    "hyperf/framework": "^3.2",
    "hyperf/http-message": "^3.2",
    "hyperf/http-server": "^3.2",
    "hyperf/redis": "^3.2",
    "hyperf/session": "^3.2",
    "hyperf/utils": "^3.2",
    "hyperf/helper": "^3.2",
    "hyperf/validation": "^3.2",
    "hyperf/view": "^3.2",
    "hyperf/view-engine": "^3.2",
    "lcobucci/jwt": "^5.3",
    "league/oauth2-server": "^9.1",
    "league/plates": "^3.6",
    "nesbot/carbon": "^2.0 || ^3.0",
    "nyholm/psr7": "^1.8",
    "phpseclib/phpseclib": "^2.0|^3.0",
    "ramsey/uuid": "^4.9",
    "richard8768/hyperf-auth": "^1.0",
    "richard8768/cookie": "^1.3",
    "richard8768/encryption": "^1.3",
    "richard8768/hashing": "^1.3"
  },
  "require-dev": {
    "friendsofphp/php-cs-fixer": "^3.94",
    "hyperf/testing": "3.2.*",
    "fakerphp/faker": "^1.23",
    "mockery/mockery": "^1.6",
    "phpstan/phpstan": "^2.1",
    "phpunit/phpunit": "^11.0",
    "swoole/ide-helper": "dev-master",
    "symfony/var-dumper": "^6.0 || ^7.0"
  },
  "autoload": {
    "psr-4": {
      "Richard\\HyperfPassport\\": "src/"
    },
    "files": [
      "src/helper.php"
    ]
  },
  "autoload-dev": {
    "psr-4": {
      "Richard\\HyperfPassport\\Tests\\": "tests/"
    }
  },
  "config": {
    "optimize-autoloader": true,
    "sort-packages": true
  },
  "minimum-stability": "dev",
  "prefer-stable": true,
  "scripts": {
    "test": "co-phpunit --prepend tests/bootstrap.php -c phpunit.xml --colors=always",
    "analyse": "phpstan analyse --memory-limit 512M -l 0 ./src",
    "analyse-types": "phpstan analyze --configuration=\"phpstan.types.neon.dist\" --memory-limit 512M -l 0 ./src",
    "cs-fix": "php-cs-fixer fix $1 --verbose"
  },
  "extra": {
    "hyperf": {
      "config": "Richard\\HyperfPassport\\ConfigProvider"
    }
  }
}
